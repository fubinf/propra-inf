            },
            "GradeEntryCreate": {
                "properties": {
                    "name": {
                        "type": "string",
                        "title": "Name"
                    },
                    "course": {
                        "type": "string",
                        "title": "Course"
                    },
                    "grade": {
                        "type": "number",
                        "title": "Grade"
                    }
                },
                "type": "object",
                "required": [
                    "name",
                    "course",
                    "grade"
                ],
                "title": "GradeEntryCreate"
            },
