                                "schema": {
                                    "items": {
                                        "$ref": "#/components/schemas/GradeEntry"
                                    },
                                    "type": "array",
                                    "title": "Response Read Grades Grades Get"
                                }
                            }
                        }
                    }
                }
            }
        },
